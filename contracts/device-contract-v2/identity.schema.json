{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://zmartify/contracts/device-contract-v2/identity.schema.json",
  "title": "Zmartify Device Identity v2",
  "type": "object",
  "required": [
    "schema_version",
    "device_id",
    "device_uuid",
    "manufacturer",
    "product_type",
    "product_model",
    "firmware"
  ],
  "properties": {
    "schema_version": { "type": "string", "const": "2.0" },
    "device_id": { "type": "string", "minLength": 1 },
    "device_uuid": { "type": "string", "format": "uuid" },
    "manufacturer": { "type": "string", "minLength": 1 },
    "product_type": { "type": "string", "minLength": 1 },
    "product_model": { "type": "string", "minLength": 1 },
    "hardware_revision": { "type": ["string", "null"] },
    "firmware": {
      "type": "object",
      "required": ["version"],
      "properties": {
        "version": { "type": "string", "minLength": 1 },
        "build_id": { "type": ["string", "null"] },
        "esp_idf_version": { "type": ["string", "null"] }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
